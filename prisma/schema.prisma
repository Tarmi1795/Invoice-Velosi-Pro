generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model workflow_presets {
  id                    String    @id @default(uuid())
  preset_name           String?
  description           String?
  visible_fields        String?   // JSON array of field keys shown in forms
  workflow_steps        String?   // JSON array of steps e.g. ["Proforma","SES","Invoice"]
  default_values        String?   // JSON object of defaults
  invoice_template      String?   // template filename
  company_profile_id    String?   // Link to a separate company/bank profile
  company_profile       company_profiles? @relation(fields: [company_profile_id], references: [id])
  created_at            DateTime? @default(now())
  updated_at            DateTime? @default(now())
  clients_and_contracts clients_and_contracts[]

  @@index([company_profile_id])
}

model company_profiles {
  id                String    @id @default(cuid())
  name              String    @unique
  address           String?
  contact           String?
  bank_details      String?
  logo_path         String?   @default("templates/logos/velosi_logo.png")
  workflow_presets  workflow_presets[]
  created_at        DateTime? @default(now())
  updated_at        DateTime? @default(now())
}

model clients_and_contracts {
  id                      String    @id @default(uuid())
  client_name             String?
  contract_no             String?   @unique
  currency                String?   @default("QAR")
  original_contract_value Float?
  running_balance         Float?
  description             String?
  contract_start_date     DateTime?
  contract_end_date       DateTime?
  preset_id               String?
  created_at              DateTime? @default(now())
  updated_at              DateTime? @default(now())
  workflow_presets         workflow_presets? @relation(fields: [preset_id], references: [id])
  projects                projects[]

  @@index([preset_id])
}

model projects {
  id                    String                 @id @default(uuid())
  contract_no           String?
  project_name          String                 @unique
  po_no                 String?
  itp_code              String?
  focal_name            String?
  focal_email           String?
  active_status         Boolean?               @default(true)
  created_at            DateTime?              @default(now())
  updated_at            DateTime?              @default(now())
  clients_and_contracts clients_and_contracts? @relation(fields: [contract_no], references: [contract_no])
  inspections_summary   inspections_summary[]
  itp_pos               itp_pos[]

  @@index([contract_no])
}

model itp_pos {
  id                String    @id @default(uuid())
  project_id        String?
  itp_po_number     String?
  po_no             String?   @unique   // 1 PO per ITP enforced at DB level
  location          String?
  inspector_id      String?
  expiry_date       DateTime?
  designation       String?
  rates             Float?
  original_budget   Float?    @default(0)
  total_invoiced    Float?    @default(0)
  status            String?   @default("Active")
  created_at        DateTime? @default(now())
  updated_at        DateTime? @default(now())
  projects          projects? @relation(fields: [project_id], references: [id])
  inspectors        inspectors? @relation(fields: [inspector_id], references: [id])
  revisions         itp_revisions[]
  inspections_summary inspections_summary[]

  @@index([project_id])
  @@index([inspector_id])
  @@index([status])
  @@index([expiry_date])
  @@index([designation])
  @@index([location])
  @@index([po_no])
}

model po_records {
  id            String    @id @default(uuid())
  po_no         String    @unique
  client_name   String?
  project_name  String?
  contract_no   String?
  amount        Float?
  status        String?   @default("Active")
  created_at    DateTime? @default(now())
  updated_at    DateTime? @default(now())

  @@index([client_name])
  @@index([status])
}

model service_orders {
  id            String    @id @default(uuid())
  sr_so_no      String    @unique   // 1 PO per SR/SO enforced at DB level
  po_no         String?   @unique
  client_name   String?
  project_name  String?
  amount        Float?
  status        String?   @default("Pending")
  created_at    DateTime? @default(now())
  updated_at    DateTime? @default(now())

  @@index([po_no])
  @@index([client_name])
  @@index([status])
}

model itp_revisions {
  id                String    @id @default(uuid())
  itp_po_id         String?
  revision_no       Int?
  revised_date      DateTime? @default(now())
  budget_adjustment Float?    @default(0) // Can be positive or negative
  new_expiry_date   DateTime?
  remarks           String?
  created_at        DateTime? @default(now())
  itp_pos           itp_pos? @relation(fields: [itp_po_id], references: [id])

  @@index([itp_po_id])
}

model inspectors {
  id                  String               @id @default(uuid())
  employee_no          String?              @unique
  full_name            String?
  job_title            String?
  base_location        String?
  created_at           DateTime?            @default(now())
  updated_at           DateTime?            @default(now())
  inspections_summary  inspections_summary[]
  itp_pos              itp_pos[]
}

model inspections_summary {
  visit_ref              String                   @id
  project_name           String?
  employee_no            String?
  itp_po_id              String?
  coordinator_name       String?
  vendor_location        String?
  inspection_start_date DateTime?
  inspection_end_date   DateTime?
  report_no             String?
  work_duration         Float?
  ot_duration           Float?
  duration_tag          String?                  @default("Hrs.")
  travel_routing        String?
  mileage               Float?
  expenses_amount       Float?
  ts_filename           String?
  ts_file_verified      Boolean?                 @default(false)
  created_at            DateTime?                @default(now())
  updated_at            DateTime?                @default(now())
  inspectors            inspectors?              @relation(fields: [employee_no], references: [employee_no])
  projects              projects?                @relation(fields: [project_name], references: [project_name])
  itp_pos               itp_pos?                 @relation(fields: [itp_po_id], references: [id])
  proformas_and_invoices proformas_and_invoices[]


  // ses_records removed — SES links to proforma, not inspection directly

  @@index([project_name])
  @@index([employee_no])
  @@index([itp_po_id])
  @@index([report_no])
  @@index([inspection_start_date])
  @@index([coordinator_name])
  @@index([vendor_location])
}

model proformas_and_invoices {
  id                    String               @id @default(uuid())
  inspection_id         String?
  itp_po_id             String?              // Links to ITP/PO (enforces 1 ITP per invoice)
  po_no                 String?              @unique   // 1 PO per invoice/SR enforced at DB level
  sr_so_no              String?
  proforma_inv_no        String?
  proforma_inv_date     DateTime?
  sap_sales_order       String?
  invoice_no            String?
  invoice_date          DateTime?
  conso_invoice_no      String?
  conso_filename        String?
  total_amount          Float?
  credit_memo_no        String?
  credit_memo_amount    Float?
  payment_status        String?              @default("Pending")
  created_at            DateTime?            @default(now())
  updated_at            DateTime?            @default(now())
  inspections_summary   inspections_summary? @relation(fields: [inspection_id], references: [visit_ref])
  ses_records           ses_records[]

  @@index([inspection_id])
  @@index([payment_status])
  @@index([proforma_inv_no])
  @@index([invoice_no])
  @@index([itp_po_id])
  @@index([po_no])
  @@index([sr_so_no])
}

model ses_records {
  id                    String                  @id @default(uuid())
  proforma_inv_id       String?
  itp_po_id             String?   // Links SES to ITP/PO
  ses_no                String?
  ses_date              DateTime?
  ses_value             Float?
  sap_work_order        String?
  po_no                 String?
  itp_code              String?
  status                String?                 @default("Pending")
  created_at            DateTime?               @default(now())
  updated_at            DateTime?               @default(now())
  proformas_and_invoices proformas_and_invoices? @relation(fields: [proforma_inv_id], references: [id])

  @@index([proforma_inv_id])
  @@index([ses_no])
  @@index([status])
  @@index([po_no])
  @@index([sap_work_order])
  @@index([itp_po_id])
}

model column_mapping_training {
  id            String    @id @default(uuid())
  entity_type   String    // e.g., "clients", "invoices", "projects", "inspections", "ses"
  excel_header  String    // Original header from Excel (normalized lowercase)
  db_field      String    // Target database field
  instruction    String?   // User-provided instruction for this mapping
  use_count     Int       @default(0) // Times this mapping was used successfully
  created_at    DateTime? @default(now())
  updated_at    DateTime? @default(now())
  
  @@unique([entity_type, excel_header])
}
